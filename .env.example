# StylePianoDiff Web 平台 - 环境变量模板
# 复制此文件为 .env 并修改为你的本地配置

# ============================================
# 数据库配置 (SQL Server)
# ============================================
# SQLAlchemy 连接字符串（使用 pyodbc 驱动）
DATABASE_URL=mssql+pyodbc://sa:YourPassword123@localhost/StylePianoDB?driver=ODBC+Driver+17+for+SQL+Server
# Windows 认证方式（如果上面不行，尝试下面的 ODBC 原生字符串，但 SQLAlchemy 可能不支持 Trusted_Connection）
# DATABASE_URL=mssql+pyodbc://localhost/StylePianoDB?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes

# ============================================
# JWT 认证配置
# ============================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# 模型项目路径配置
# ============================================
MODEL_PROJECT_PATH=D:\pycharm\stylepianodiff
CHECKPOINT_PATH=D:\pycharm\stylepianodiff\outputs\diffusion\stage3_best.pt
MODEL_CONFIG_PATH=D:\pycharm\stylepianodiff\configs\train_diffusion.yaml

# ============================================
# 文件存储路径配置
# ============================================
UPLOAD_DIR=D:\pycharm\stylepianodiff-web\backend\uploads
GENERATED_DIR=D:\pycharm\stylepianodiff-web\backend\generated

# ============================================
# 生成任务配置
# ============================================
GENERATION_TIMEOUT=120
DEFAULT_ALPHA=1.0
DEFAULT_TEMPERATURE=1.0
DEFAULT_TARGET_BARS=8

# ============================================
# FastAPI 服务配置
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:5173

# ============================================
# 应用配置
# ============================================
APP_NAME=StylePianoDiff API
APP_VERSION=1.0.0
DEBUG=False

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
